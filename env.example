# FastCode Environment Variables

OPENAI_API_KEY=your_openai_api_key_here
MODEL=your_model
BASE_URL=your_base_url

# OPENAI_API_KEY=your_openai_api_key_here
# MODEL=google/gemini-3-flash-preview
# BASE_URL=https://openrouter.ai/api/v1

# Ollama
# OPENAI_API_KEY=ollama
# MODEL=qwen3-coder-30b_fastcode
# BASE_URL=http://localhost:11434/v1


# ===== Nanobot Model (Agent Reasoning / Feishu Conversations) =====
NANOBOT_MODEL=minimax/minimax-m2.1

# ===== Nanobot Control Plane Security / Metrics =====
# Leave empty for local demo runs. Set these for production or shared demos.
# NANOBOT_CONTROL_PLANE__API_KEY=replace-with-a-long-random-secret
# NANOBOT_CONTROL_PLANE__REQUIRE_API_KEY=true
# NANOBOT_CONTROL_PLANE__RATE_LIMIT_PER_MINUTE=120
# NANOBOT_CONTROL_PLANE__RATE_LIMIT_WINDOW_SECONDS=60